# --- Configuração de Provedor (Escolha um) ---
# AI_PROVIDER=openai
# AI_PROVIDER=google-ai-gemini

# --- Para OpenAI, Groq, Ollama (AI_PROVIDER=openai) ---
AI_API_KEY=gsk_your_key_here
AI_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL_NAME=llama-3.3-70b-versatile

# --- Para Google Gemini (AI_PROVIDER=google-ai-gemini) ---
# Obtenha em: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=sua-chave-do-google-aqui
# GEMINI_MODEL_NAME=gemini-1.5-flash

AI_TIMEOUT=60s

# --- Banco de Dados ---
DB_USERNAME=quarkus
DB_PASSWORD=quarkus

# --- E-mail (Mailpit) ---
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_FROM=noreply@resume-intelligence.com

# --- Outras Configurações ---
ADMIN_EMAIL=admin@admin.com
APP_BASE_URL=http://localhost:8080
APP_FRONTEND_URL=http://localhost:8081

# Segurança e CORS
APP_JWT_ISSUER=https://acme.org/
CORS_ORIGINS=http://localhost,http://localhost:4200,http://localhost:80,http://localhost:8081

# Regionalização
APP_REPORT_TIMEZONE=America/Sao_Paulo
